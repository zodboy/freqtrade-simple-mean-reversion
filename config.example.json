{
    "max_open_trades": 3,
    "stake_currency": "USDT",
    "stake_amount": "unlimited",
    "tradable_balance_ratio": 0.99,
    "fiat_display_currency": "USD",
    "dry_run": true,
    "dry_run_wallet": 1000,
    "cancel_open_orders_on_exit": false,
    "trading_mode": "spot",
    "margin_mode": "",
    "exchange": {
        "name": "okx",
        "key": "",
        "secret": "",
        "ccxt_config": {
            "enableRateLimit": true,
            "rateLimit": 2000
        },
        "ccxt_async_config": {
            "enableRateLimit": true,
            "rateLimit": 2000
        }
    },
    "pairlists": [
        {
            "method": "StaticPairList",
